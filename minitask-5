FUNTION HitungDiskonBelanja
  DECLARE jumBelanja, diskon, totBelanja : INTEGER
BEGIN
  INPUT (jumBelanja)
  IF jumBelanja < 500.000
  THEN
    diskon <- 0
  ELSE IF jumBelanja >= 500.000 AND <= 1.000.000
  THEN
    diskon <- 500.000 x 5%
  ELSE IF jumBelanja > 1.000.000
  THEN
    diskon <- 500.000 x 10%
  ENDIF
  totBelanja <- jumBelanja - diskon
  OUTPUT("Total Belanja : ", totBelanja)
